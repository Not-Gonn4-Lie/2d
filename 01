  #include <iostream>
  #include <vector>
  using namespace std;

  class SET {
      vector<int> s;

  public:
      // Input function
      void input() {
          int n, x;
          cout << "Enter number of elements: ";
          cin >> n;
          cout << "Enter elements:\n";
          for(int i = 0; i < n; i++) {
              cin >> x;
              s.push_back(x);
          }
      }

      // Display set
      void display() {
          cout << "{ ";
          for(int i : s)
              cout << i << " ";
          cout << "}\n";
      }

      // a. isMember
      bool isMember(int x) {
          for(int i : s) {
              if(i == x)
                  return true;
          }
          return false;
      }

    // b. Power set
    void powerSet() {
        int n = s.size();
        int pow_size = 1 << n;

        cout << "Power Set:\n";
        for(int i = 0; i < pow_size; i++) {
            cout << "{ ";
            for(int j = 0; j < n; j++) {
                if(i & (1 << j))
                    cout << s[j] << " ";
            }
            cout << "}\n";
        }
    }

    // c. subset
    bool isSubset(SET s2) {
        for(int i : s2.s) {
            if(!isMember(i))
                return false;
        }
        return true;
    }

    // d. Union
    SET Union(SET s2) {
        SET result = *this;
        for(int i : s2.s) {
            if(!result.isMember(i))
                result.s.push_back(i);
        }
        return result;
    }

    // d. Intersection
    SET Intersection(SET s2) {
        SET result;
        for(int i : s) {
            if(s2.isMember(i))
                result.s.push_back(i);
        }
        return result;
    }

    // e. Complement
    SET Complement(SET universal) {
        SET result;
        for(int i : universal.s) {
            if(!isMember(i))
                result.s.push_back(i);
        }
        return result;
    }

    // f. Difference
    SET Difference(SET s2) {
        SET result;
        for(int i : s) {
            if(!s2.isMember(i))
                result.s.push_back(i);
        }
        return result;
    }

    // f. Symmetric Difference
    SET SymmetricDifference(SET s2) {
        SET result;
        for(int i : s) {
            if(!s2.isMember(i))
                result.s.push_back(i);
        }
        for(int i : s2.s) {
            if(!isMember(i))
                result.s.push_back(i);
        }
        return result;
    }

    // g. Cartesian Product
    void CartesianProduct(SET s2) {
        cout << "Cartesian Product:\n";
        for(int i : s) {
            for(int j : s2.s) {
                cout << "(" << i << "," << j << ") ";
            }
            cout << endl;
        }
    }
};

int main() {
    SET A, B, U;

    cout << "Enter Set A:\n";
    A.input();

    cout << "Enter Set B:\n";
    B.input();

    cout << "Enter Universal Set:\n";
    U.input();

    cout << "\nSet A: "; A.display();
    cout << "Set B: "; B.display();

    // isMember
    int x;
    cout << "\nEnter element to check in A: ";
    cin >> x;
    cout << (A.isMember(x) ? "Present\n" : "Not Present\n");

    // Power set
    A.powerSet();

    // Subset
    cout << "\nIs B subset of A? ";
    cout << (A.isSubset(B) ? "Yes\n" : "No\n");

    // Union & Intersection
    SET uni = A.Union(B);
    cout << "Union: "; uni.display();

    SET inter = A.Intersection(B);
    cout << "Intersection: "; inter.display();

    // Complement
    SET comp = A.Complement(U);
    cout << "Complement of A: "; comp.display();

    // Difference
    SET diff = A.Difference(B);
    cout << "A - B: "; diff.display();

    // Symmetric Difference
    SET sym = A.SymmetricDifference(B);
    cout << "Symmetric Difference: "; sym.display();

    // Cartesian Product
    A.CartesianProduct(B);

    return 0;
}
