#practical_05

a[0] = 9   (constant term)  
a[1] = 2   (n¹)  
a[2] = 4   (n²)

#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int degree, n;
    
    cout << "Enter degree of polynomial: ";
    cin >> degree;

    int a[10];

    cout << "Enter coefficients (from constant term to highest degree):\n";
    for(int i = 0; i <= degree; i++) {
        cin >> a[i];
    }

    cout << "Enter value of n: ";
    cin >> n;

    int result = 0;

    // Evaluate polynomial
    for(int i = 0; i <= degree; i++) {
        result += a[i] * pow(n, i);
    }

    cout << "Value of polynomial = " << result;

    return 0;
}
